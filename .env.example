# ── 필수 ────────────────────────────────────────────────
# 네이버 쇼핑 검색 API (https://developers.naver.com/)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Anthropic Console API 키 (https://console.anthropic.com/ 에서 1회 발급)
# Agent SDK 웹리서치(비교가/쿠팡/리뷰)에 사용. 미설정 시 네이버 결과만으로 진행.
ANTHROPIC_API_KEY=

# ── 서버/스케줄 (선택, 아래는 기본값) ─────────────────────
PORT=7777
# 매일 자동 수집 시각 (HH:mm, 24h)
COLLECT_TIME=09:00
# DB 파일 경로 (기본: <repo>/data/price.db)
# DB_PATH=/Users/daegun/Workspace/price/data/price.db
# 임포트할 기존 이력 JSON 경로
LEGACY_HISTORY_JSON=/Users/daegun/Documents/Claude/Projects/자동화/daily-price-tracker/price_history.json
# 가격 이력 보존 일수
HISTORY_RETENTION_DAYS=90

# ── 알림 (선택) ──────────────────────────────────────────
# 이메일 알림 on/off
NOTIFY_EMAIL=true
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# 카카오톡 "나에게 보내기" 알림 on/off
NOTIFY_KAKAO=true
# 카카오 REST 액세스 토큰 (talk_message 스코프). 미설정 시 카카오 알림은 경고 후 건너뜀.
KAKAO_ACCESS_TOKEN=
