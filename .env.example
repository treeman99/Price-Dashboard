# ── 필수 ────────────────────────────────────────────────
# 네이버 쇼핑 검색 API (https://developers.naver.com/)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Anthropic Console API 키 (https://console.anthropic.com/ 에서 1회 발급)
# Agent SDK 웹리서치(비교가/리뷰) + 팝업/전시 큐레이션에 사용. 미설정 시 Claude Code 로그인 자격증명으로 동작.
ANTHROPIC_API_KEY=

# ── 팝업/전시 날짜 검증 (insane-engine, 선택) ─────────────
# 차단된 실제 행사 페이지를 우회 fetch 해 시작/종료일을 검증하고 종료된 행사를 제외한다.
# 최초 1회: bash tools/insane-engine/setup.sh  (python venv + curl_cffi/bs4 설치)
# EVENTS_VERIFY_DATES=true       # false 로 끄면 엔진 없이 큐레이션만
# INSANE_PYTHON=                 # 기본: tools/insane-engine/.venv/bin/python3
# INSANE_ENGINE_DIR=            # 기본: tools/insane-engine
# INSANE_MAX_ATTEMPTS=18        # fetch 격자 시도 상한

# ── 서버/스케줄 (선택, 아래는 기본값) ─────────────────────
PORT=7777
# 매일 가격 수집 시각 (HH:mm, 24h)
COLLECT_TIME=09:00
# 매일 팝업/전시 갱신 시각 (HH:mm, 24h)
EVENTS_COLLECT_TIME=10:00
# DB 파일 경로 (기본: <repo>/data/price.db)
# DB_PATH=/Users/daegun/Workspace/price/data/price.db
# 임포트할 기존 이력 JSON 경로
LEGACY_HISTORY_JSON=/Users/daegun/Documents/Claude/Projects/자동화/daily-price-tracker/price_history.json
# 가격 이력 보존 일수
HISTORY_RETENTION_DAYS=90

# ── 알림 (선택) ──────────────────────────────────────────
# 이메일 알림 on/off
NOTIFY_EMAIL=true
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
